<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Triggers — DBBD</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;600&family=IBM+Plex+Sans:wght@400;500;600&display=swap" rel="stylesheet">

    <style>
        :root {
            --bg:        #0d1117;
            --surface:   #161b22;
            --border:    #21262d;
            --accent:    #f97316;
            --accent-dim:#7c3003;
            --text:      #e6edf3;
            --muted:     #8b949e;
            --hover:     #1c2128;
            --danger:    #f85149;
            --green:     #3fb950;
        }

        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'IBM Plex Sans', sans-serif;
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
            padding: 48px 24px;
        }

        /* ── Page wrapper ── */
        .page-wrapper {
            max-width: 1100px;       /* <-- this is the key fix */
            margin: 0 auto;
        }

        /* ── Header ── */
        .page-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 32px;
            padding-bottom: 20px;
            border-bottom: 1px solid var(--border);
        }

        .page-header h1 {
            font-size: 1.1rem;
            font-weight: 600;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            color: var(--muted);
        }

        .page-header h1 span {
            color: var(--accent);
        }

        .badge {
            font-family: 'IBM Plex Mono', monospace;
            font-size: 0.75rem;
            background: var(--accent-dim);
            color: var(--accent);
            border: 1px solid var(--accent);
            border-radius: 4px;
            padding: 2px 10px;
            opacity: 0;
            transition: opacity 0.3s;
        }
        .badge.visible { opacity: 1; }

        /* ── Table card ── */
        .table-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 8px;
            overflow: hidden;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        thead tr {
            background: var(--bg);
            border-bottom: 1px solid var(--border);
        }

        th {
            font-family: 'IBM Plex Mono', monospace;
            font-size: 0.7rem;
            font-weight: 600;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            color: var(--muted);
            padding: 14px 20px;
            text-align: left;
        }

        tbody tr {
            border-bottom: 1px solid var(--border);
            transition: background 0.15s;
            animation: rowIn 0.3s ease both;
        }
        tbody tr:last-child { border-bottom: none; }
        tbody tr:hover { background: var(--hover); }

        @keyframes rowIn {
            from { opacity: 0; transform: translateY(6px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        td {
            padding: 14px 20px;
            font-size: 0.875rem;
            vertical-align: middle;
        }

        /* id column */
        td:first-child {
            font-family: 'IBM Plex Mono', monospace;
            color: var(--muted);
            font-size: 0.8rem;
            width: 52px;
        }

        /* token column */
        .token-cell {
            font-family: 'IBM Plex Mono', monospace;
            font-size: 0.78rem;
            color: var(--accent);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            max-width: 260px;
        }

        /* reminder column */
        .reminder-cell {
            color: var(--text);
            max-width: 220px;
        }

        /* date column */
        .date-cell {
            font-family: 'IBM Plex Mono', monospace;
            font-size: 0.78rem;
            color: var(--muted);
            white-space: nowrap;
        }

        /* email */
        .email-cell {
            color: var(--muted);
            font-size: 0.82rem;
        }

        /* Empty / loading states  */
        .state-row td {
            padding: 48px 20px;
            text-align: center;
            color: var(--muted);
            font-size: 0.875rem;
        }

        .spinner {
            display: inline-block;
            width: 16px; height: 16px;
            border: 2px solid var(--border);
            border-top-color: var(--accent);
            border-radius: 50%;
            animation: spin 0.7s linear infinite;
            vertical-align: middle;
            margin-right: 8px;
        }
        @keyframes spin { to { transform: rotate(360deg); } }
    </style>
</head>

<body>
    <div class="page-wrapper">

        <header class="page-header">
            <h1>DBBD / <span>Deployed Baits</span></h1>
            <span class="badge" id="count-badge">— baits</span> <!--Count Total Baits For the specific User-->
        </header>

        <div class="table-card">
            <table id="trigger-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Token</th>
                        <th>Callback Email</th>
                        <th>Reminder</th>
                        <th>Created</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody id="trigger-table-body">
                    <tr class="state-row">
                        <td colspan="5">
                            <span class="spinner"></span> Loading baits…
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>

    </div>

    <script>
        async function loadTriggers() {
            const token = localStorage.getItem('token');

            if (!token) {
                window.location.href = '/auth/login';
                return;
            }

            try {
                const response = await fetch('/api/v1/triggers', {
                    method: 'GET',
                    headers: {
                        'Authorization': `Bearer ${token}`,
                        'Content-Type': 'application/json'
                    }
                });

                if (response.status === 401) {
                    alert("Session expired. Redirecting to login.");
                    window.location.href = "/auth/login";
                    return;
                }

                const result = await response.json();
                const tableBody = document.getElementById('trigger-table-body');
                tableBody.innerHTML = '';

                if (!response.ok) {
                    tableBody.innerHTML = `<tr class="state-row"><td colspan="5">Error: ${result.message || 'Could not fetch data'}</td></tr>`;
                    return;
                }

                if (result.data.length === 0) {
                    tableBody.innerHTML = '<tr class="state-row"><td colspan="5">No baits deployed yet.</td></tr>';
                    return;
                }

                // Update badge
                const badge = document.getElementById('count-badge');
                badge.textContent = `${result.data.length} bait${result.data.length !== 1 ? 's' : ''}`;
                badge.classList.add('visible');

                // Iterating all user's baits then printing
                result.data.forEach((trigger, i) => {
                    const row = document.createElement('tr');
                    row.style.animationDelay = `${i * 40}ms`;
                    row.innerHTML = `
                        <td>${trigger.id}</td>
                        <td class="token-cell" title="${trigger.token}">${trigger.token}</td>
                        <td class="email-cell">${trigger.callback_email}</td>
                        <td class="reminder-cell">${trigger.reminder}</td>
                        <td class="date-cell">${new Date(trigger.created_at).toLocaleString()}</td>
                    `;
                    tableBody.appendChild(row);
                });

            } catch (err) {
                console.error("Network or parse error:", err);
                document.getElementById('trigger-table-body').innerHTML =
                    '<tr class="state-row"><td colspan="5">Network error. check console.</td></tr>';
            }
        }

        window.onload = loadTriggers;
    </script>
</body>
</html>
